# ─────────────────────────────────────────────────────────────
# GDIS Rent — Environment template
# Copy this file to `.env` and fill with real values.
# NEVER commit `.env` — it's in .gitignore.
# In Vercel, set these under Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase — client-safe (embedded in bundle, relies on RLS)
VITE_SUPABASE_URL="https://<your-project>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"
VITE_SUPABASE_PROJECT_ID="<your-project-id>"

# Cloudflare Turnstile CAPTCHA — client widget site key
VITE_TURNSTILE_SITE_KEY="<your-turnstile-site-key>"

# Google Analytics 4 — leave empty until GA4 property is created
VITE_GA4_ID=""

# ─── Server-only (set in Supabase Edge Function secrets, NOT exposed to client) ───
# Supabase service role key (bypasses RLS) — use only in edge functions
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Cloudflare Turnstile verification secret — validates the client token
TURNSTILE_SECRET_KEY="<your-turnstile-secret>"

# Prerender.io token — set in Vercel env vars (server-only)
PRERENDER_TOKEN="<your-prerender-token>"
