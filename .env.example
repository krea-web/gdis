# ─────────────────────────────────────────────────────────────
# GDIS Rent — Environment template
# Copy this file to `.env` and fill with real values.
# NEVER commit `.env` — it's in .gitignore.
# In Vercel, set these under Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase — client-safe (embedded in bundle, relies on RLS)
PUBLIC_SUPABASE_URL="https://<your-project>.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"

# Cloudflare Turnstile CAPTCHA — client widget site key
PUBLIC_TURNSTILE_SITE_KEY="<your-turnstile-site-key>"

# Google Analytics 4 — leave empty until GA4 property is created (defaults to G-0SH3YF3Y65)
PUBLIC_GA_ID=""

# ─── Server / build-time only (NOT exposed to client) ───
# Supabase service role key (bypasses RLS) — used at build for prebuild data fetching
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Cloudflare Turnstile verification secret — validates the client token (in edge functions)
TURNSTILE_SECRET_KEY="<your-turnstile-secret>"
