---
export interface Props {
  name: string;
  subtitle: string;
  bgImage: string;
  h1Prefix?: string;
  h1Accent?: string;
}

const { name, subtitle, bgImage, h1Prefix = "Noleggio Auto a", h1Accent } = Astro.props;
const accent = h1Accent ?? name;
const trackId = `localita_hero_${name.toLowerCase().replace(/\s+/g, "_")}`;
---

<section class="relative min-h-[90vh] flex items-end pb-20 overflow-hidden">
  <div class="absolute inset-0 bg-cover bg-center" style={`background-image:url(${bgImage})`}></div>
  <div class="absolute inset-0 bg-gradient-to-t from-background via-black/50 to-black/30"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,hsl(var(--primary)/0.2),transparent_60%)]"></div>

  <div class="container relative z-10 px-4">
    <div class="max-w-2xl">
      <div class="flex items-center gap-2 mb-4" data-reveal>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="text-xs font-semibold tracking-[0.3em] uppercase text-primary">{name}</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-black text-white leading-[0.95] mb-6" data-reveal data-reveal-delay="100">
        {h1Prefix}<br />
        <span class="text-primary">{accent}</span>
      </h1>

      <p class="text-base md:text-lg text-white/70 mb-8" data-reveal data-reveal-delay="200">
        {subtitle}
      </p>

      <div class="flex flex-wrap gap-3" data-reveal data-reveal-delay="300">
        <a
          href="/prenotaora"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 text-base font-semibold rounded-full bg-primary text-primary-foreground hover:bg-brand-blue-deep shadow-lg shadow-primary/30 transition-all"
        >
          Prenota Ora
        </a>
        <a
          href="https://wa.me/393200625543"
          target="_blank"
          rel="noopener noreferrer"
          data-wa-track={trackId}
          class="inline-flex items-center justify-center gap-2 h-12 px-8 text-base font-semibold rounded-full border-2 border-white/20 bg-white/10 backdrop-blur-md text-white hover:bg-white/20 transition-all"
        >
          Consegna VIP
        </a>
      </div>
    </div>
  </div>
</section>
