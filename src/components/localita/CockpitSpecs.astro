---
type Spec = { label: string; value: string; icon: "license" | "seats" | "use" | "delivery" };

export interface Props {
  vehicleName: string;
  specs: Spec[];
}

const { vehicleName, specs } = Astro.props;
---

<section class="py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-primary/90 to-slate-900"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,hsl(var(--primary)/0.3),transparent_60%)]"></div>

  <div class="container relative z-10 px-4">
    <div class="text-center mb-14" data-reveal>
      <p class="text-sm font-semibold tracking-widest uppercase text-white/50 mb-3">Specifiche</p>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-white">{vehicleName}</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
      {specs.map((spec, i) => (
        <div
          class="relative rounded-2xl p-6 bg-white/5 backdrop-blur-xl border border-white/10 text-center group hover:border-primary/40 transition-all duration-300"
          data-reveal
          data-reveal-delay={String(i * 100)}
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mx-auto mb-4">
              {spec.icon === "license" && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/></svg>}
              {spec.icon === "seats" && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
              {spec.icon === "use" && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M12 14a4 4 0 0 0 0-8 4 4 0 0 0 0 8z"/><path d="M2 22a10 10 0 0 1 20 0"/></svg>}
              {spec.icon === "delivery" && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>}
            </div>
            <p class="text-xs text-white/50 uppercase tracking-wider mb-1">{spec.label}</p>
            <p class="text-lg font-bold text-white">{spec.value}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
