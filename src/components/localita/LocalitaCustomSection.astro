---
export interface Props {
  variant?: "airport" | "port" | "left-image" | "right-image";
  badge?: string;
  title: string;
  body: string;
  bullets?: string[];
  callout?: { title: string; text: string };
  image: string;
  imageAlt: string;
  bgClass?: string;
}

const {
  variant = "right-image",
  badge,
  title,
  body,
  bullets,
  callout,
  image,
  imageAlt,
  bgClass = "bg-background",
} = Astro.props;

const reverseImage = variant === "port" || variant === "left-image";
const icon = variant === "airport" ? "plane" : variant === "port" ? "ship" : null;
---

<section class:list={["py-24 md:py-32 relative overflow-hidden", bgClass]}>
  <div class="container px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div data-reveal class:list={[reverseImage ? "lg:order-2" : ""]}>
        {(badge || icon) && (
          <div class="flex items-center gap-3 mb-4">
            {icon === "plane" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
            )}
            {icon === "ship" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1s1.2 1 2.5 1c2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M12 10v4"/><path d="M12 2v3"/></svg>
            )}
            {badge && (
              <span class="text-xs uppercase tracking-widest text-primary font-semibold">{badge}</span>
            )}
          </div>
        )}
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-6">{title}</h2>
        <p class="text-muted-foreground leading-relaxed mb-6" set:html={body} />
        {bullets && bullets.length > 0 && (
          <ul class="space-y-3">
            {bullets.map((b) => (
              <li class="flex items-start gap-2 text-muted-foreground">
                <span class="text-primary font-bold">✓</span>
                <span set:html={b} />
              </li>
            ))}
          </ul>
        )}
        {callout && (
          <div class="bg-card/60 border border-border/50 rounded-xl p-5 mt-6">
            <h3 class="text-lg font-semibold text-foreground mb-2">{callout.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed" set:html={callout.text} />
          </div>
        )}
      </div>

      <div class="relative aspect-[4/3] rounded-2xl overflow-hidden" data-reveal data-reveal-delay="100" class:list={[reverseImage ? "lg:order-1" : ""]}>
        <img src={image} alt={imageAlt} loading="lazy" decoding="async" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-background/40 to-transparent"></div>
      </div>
    </div>
  </div>
</section>
