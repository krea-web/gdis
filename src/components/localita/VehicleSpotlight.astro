---
export interface Props {
  tag: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  badges?: string[];
  reverse?: boolean;
}

const { tag, title, description, image, imageAlt, badges = [], reverse = false } = Astro.props;
---

<section class="py-24 md:py-32 bg-background relative overflow-hidden">
  <div class="container px-4">
    <div class="grid lg:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">
      <div data-reveal class:list={[reverse ? "lg:order-2" : ""]}>
        <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-3">{tag}</p>
        <h2 class="text-3xl md:text-5xl font-display font-bold text-foreground mb-6 leading-tight">
          {title}
        </h2>
        <p class="text-lg text-muted-foreground leading-relaxed mb-8" set:html={description} />
        {badges.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {badges.map((b) => (
              <span class="px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-semibold">{b}</span>
            ))}
          </div>
        )}
      </div>

      {image && (
        <div class="relative" data-reveal data-reveal-delay="100" class:list={[reverse ? "lg:order-1" : ""]}>
          <div class="rounded-2xl overflow-hidden shadow-2xl shadow-primary/10 aspect-[4/3] md:aspect-[16/10]">
            <img src={image} alt={imageAlt || title} loading="lazy" decoding="async" class="w-full h-full object-cover object-center" />
          </div>
          <div class="absolute -bottom-6 -right-6 w-40 h-40 bg-primary/10 rounded-full blur-3xl -z-10"></div>
          <div class="absolute -top-6 -left-6 w-24 h-24 bg-primary/5 rounded-full blur-2xl -z-10"></div>
        </div>
      )}
    </div>
  </div>
</section>
