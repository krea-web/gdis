---
type Locale = { name: string; type: "ristorante" | "aperitivo" | "club" | "lounge"; desc: string };

export interface Props {
  name: string;
  locali: Locale[];
}

const { name, locali } = Astro.props;

const typeMeta: Record<Locale["type"], { label: string; iconKey: string }> = {
  ristorante: { label: "Ristorante", iconKey: "utensils" },
  aperitivo: { label: "Aperitivo", iconKey: "wine" },
  club: { label: "Club", iconKey: "music" },
  lounge: { label: "Lounge", iconKey: "sunset" },
};
---

<section class="py-24 md:py-32 bg-background relative">
  <div class="container px-4">
    <div class="text-center mb-16" data-reveal>
      <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-3">Vita Notturna</p>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-foreground">
        Locali & Ristoranti a {name}
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {locali.map((locale, i) => {
        const meta = typeMeta[locale.type];
        return (
          <div
            class="group rounded-2xl p-6 bg-background/60 backdrop-blur-xl border border-border/50 hover:border-primary/30 hover:shadow-[0_10px_40px_hsl(var(--primary)/0.1)] transition-all duration-300"
            data-reveal
            data-reveal-delay={String((i % 3) * 80)}
          >
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                {meta.iconKey === "utensils" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>}
                {meta.iconKey === "wine" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/><path d="M12 15a5 5 0 0 0 5-5c0-2-.5-3.5-2-7H9c-1.5 3.5-2 5-2 7a5 5 0 0 0 5 5Z"/></svg>}
                {meta.iconKey === "music" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>}
                {meta.iconKey === "sunset" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 10V2"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m16 6-4 4-4-4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg>}
              </div>
              <div>
                <p class="font-semibold text-foreground">{locale.name}</p>
                <p class="text-xs text-primary font-medium uppercase tracking-wider">{meta.label}</p>
              </div>
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed">{locale.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
