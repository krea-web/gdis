---
type FaqItem = { q: string; a: string };

export interface Props {
  name: string;
  faqs: FaqItem[];
}

const { name, faqs } = Astro.props;
---

<section class="py-24 md:py-32 bg-background relative">
  <div class="container px-4 max-w-3xl mx-auto">
    <div class="text-center mb-16" data-reveal>
      <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-3">FAQ</p>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-foreground">
        Domande su {name}
      </h2>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details
          class:list={[
            "faq-item rounded-xl border px-6",
            i < 2
              ? "bg-primary text-primary-foreground border-primary/80"
              : "bg-background border-border/50",
          ]}
        >
          <summary class:list={["py-5 flex items-center justify-between gap-4 text-left font-semibold", i < 2 ? "text-primary-foreground" : "text-foreground"]}>
            <span>{faq.q}</span>
            <svg class:list={["faq-chevron h-5 w-5 flex-shrink-0", i < 2 ? "text-primary-foreground" : "text-foreground"]} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class:list={["pb-5 leading-relaxed", i < 2 ? "text-primary-foreground/80" : "text-muted-foreground"]}>
            <p set:html={faq.a} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
