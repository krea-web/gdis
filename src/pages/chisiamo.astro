---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FaqList from "@/components/FaqList.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { buildFaqSchema } from "@/lib/siteSchema";
import { supabaseImg } from "@/lib/img";

const heroUrl = supabaseImg(
  "asset/gdisrentservice-noleggio-auto-scooter-quad-olbia.webp",
  { raw: true },
);
const touristUrl = supabaseImg(
  "vehicles/gdisrent-consegna-auto-scooter-quad-a-domicilio.webp",
  { raw: true },
);
const transportUrl = supabaseImg(
  "asset/gdisrentservice-trasporto-merci-trasporti-eccezionali-trasporto-di-imbarcazioni.webp",
  { raw: true },
);
const gdisLogo = supabaseImg("asset/GDISlogo.webp", { raw: true });

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Chi Siamo", url: "/chisiamo" },
];

const timelineItems = [
  {
    icon: "star",
    title: "Nati per il Turismo",
    text: "Non siamo un vecchio autonoleggio. Siamo una startup digitale nata nel 2025, costruita da zero per offrire la miglior esperienza di mobilità turistica in Costa Smeralda.",
  },
  {
    icon: "car",
    title: "Flotta 2025",
    text: "Ogni veicolo della nostra flotta è nuovo, revisionato e assicurato. City Car, Scooter, Quad e Auto di Lusso su richiesta — solo il meglio per le tue vacanze.",
  },
  {
    icon: "phone",
    title: "100% Digitale",
    text: "Prenota online in 2 minuti, firma digitalmente il contratto e sei pronto a partire. Nessuna coda, nessun modulo cartaceo, nessuno stress.",
  },
  {
    icon: "zap",
    title: "Consegna VIP",
    text: "Il veicolo arriva direttamente a te: al tuo yacht, al tuo hotel, alla tua villa. Da Palau a San Teodoro, copriamo tutta la Gallura e la Costa Smeralda.",
  },
];

const marqueeItems = [
  "Noleggio Auto",
  "Consegne VIP",
  "Scooter & Quad",
  "Trasporti Speciali",
  "Assistenza 24/7",
  "Costa Smeralda",
];

const faqs = [
  { q: "Quali documenti servono per noleggiare?", a: "Patente di guida valida, carta d'identità o passaporto, e carta di credito intestata al conducente. Per i cittadini extra-UE serve anche il permesso internazionale di guida." },
  { q: "È possibile aggiungere un secondo guidatore?", a: "Sì, è possibile aggiungere un secondo guidatore al momento della prenotazione o al ritiro del veicolo. Il secondo guidatore deve presentare gli stessi documenti del conducente principale." },
  { q: "Qual è la politica di cancellazione?", a: "La cancellazione è gratuita fino a 48 ore prima del ritiro. Per cancellazioni tardive viene applicata una penale pari al 50% del costo totale del noleggio." },
  { q: "Quali sono i metodi di pagamento accettati?", a: "Accettiamo carte di credito Visa, Mastercard e American Express. Il pagamento avviene al ritiro del veicolo. Per le prenotazioni online è richiesta una pre-autorizzazione sulla carta." },
  { q: "I veicoli sono coperti da assicurazione?", a: "Tutti i veicoli includono RCA, furto e incendio. È possibile acquistare coperture aggiuntive come la Kasko e la riduzione della franchigia." },
  { q: "È possibile riconsegnare il veicolo in un luogo diverso?", a: "Sì, offriamo il servizio di riconsegna in location diverse con un piccolo supplemento. Contattaci per conoscere le location disponibili." },
  { q: "Offrite consegna VIP a yacht e hotel?", a: "Assolutamente sì! Il nostro servizio Consegna VIP porta il veicolo direttamente al tuo yacht, hotel o villa privata in tutta la Costa Smeralda e Gallura." },
  { q: "Come posso contattarvi per le auto luxury?", a: "Per le auto luxury ti consigliamo di contattarci direttamente via WhatsApp al +39 352 045 9150 per verificare disponibilità e ricevere un preventivo dedicato." },
];

const faqSchema = buildFaqSchema(faqs);

const repeatedMarquee = [...marqueeItems, ...marqueeItems, ...marqueeItems, ...marqueeItems];
---

<BaseLayout
  title="Chi Siamo — GDIS Service Srl | Noleggio Veicoli in Costa Smeralda"
  description="GDIS Service Srl: la nuova era della mobilità in Sardegna. Noleggio 100% digitale di city car, scooter, quad e auto VIP in Costa Smeralda dal 2025."
  canonical="/chisiamo"
  jsonLd={faqSchema}
  breadcrumbs={breadcrumbs}
>
  {/* Hero */}
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src={heroUrl}
        alt="GDIS Mobilità Costa Smeralda"
        class="w-full h-full object-cover"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900/80 via-slate-900/60 to-slate-900 z-[1]"></div>
    <div class="relative z-10 text-center px-4 max-w-5xl">
      <p class="text-blue-400 font-display text-sm font-semibold uppercase tracking-[0.3em] mb-4 block animate-fade-in">
        DAL 2025 IN SARDEGNA
      </p>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white leading-tight mb-6 drop-shadow-2xl animate-fade-in">
        Noleggio Auto, Scooter e Quad
      </h1>
      <p class="text-slate-200 text-lg md:text-2xl font-light mt-8 max-w-3xl mx-auto leading-relaxed animate-fade-in">
        Nati nel 2025 per offrirti veicoli di ultima generazione, un processo 100% digitale e
        consegne VIP direttamente al tuo yacht o hotel.
      </p>
      <div class="w-32 md:w-48 h-[3px] bg-primary mx-auto mt-10 shadow-[0_0_20px_hsl(var(--primary)/0.6)]"></div>
    </div>
  </section>

  {/* Vertical timeline */}
  <section class="relative py-24 md:py-36 bg-background overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-slate-900 to-transparent pointer-events-none"></div>
    <div class="container px-4 relative z-10 max-w-3xl mx-auto pt-16">
      <div class="mb-16 md:mb-20" data-reveal>
        <span class="text-primary font-display text-xs font-bold uppercase tracking-[0.4em] mb-4 block">
          Il Nostro DNA
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-black text-foreground leading-tight">
          Perché scegliere <span class="italic font-light text-primary">GDIS</span>
        </h2>
      </div>

      {timelineItems.map((item, i) => (
        <div class="relative flex gap-6 md:gap-10" data-reveal data-reveal-delay={String(i * 100)}>
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="relative z-10 w-14 h-14 md:w-16 md:h-16 rounded-2xl bg-primary flex items-center justify-center shadow-[0_0_30px_hsl(var(--primary)/0.4)]">
              {item.icon === "star" && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>}
              {item.icon === "car" && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.5 2.8C1.4 11.3 1 12.1 1 13v3c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>}
              {item.icon === "phone" && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>}
              {item.icon === "zap" && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
            </div>
            {i < timelineItems.length - 1 && (
              <div class="w-px flex-1 bg-gradient-to-b from-primary/50 to-primary/10 min-h-[60px]"></div>
            )}
          </div>
          <div class="pb-14 md:pb-20">
            <span class="text-primary font-display text-xs font-bold uppercase tracking-[0.3em]">
              0{i + 1}
            </span>
            <h3 class="font-display text-2xl md:text-3xl font-bold text-foreground mt-1 mb-3">{item.title}</h3>
            <p class="text-muted-foreground text-base md:text-lg font-light leading-relaxed max-w-lg">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* Tourist rental */}
  <section class="relative py-32 md:py-48 bg-muted overflow-hidden">
    <div class="container px-4 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center max-w-7xl mx-auto">
        <div class="relative order-2 lg:order-1" data-reveal>
          <div class="relative rounded-3xl overflow-hidden aspect-[4/5] shadow-2xl">
            <img src={touristUrl} alt="Noleggio turistico Costa Smeralda" loading="lazy" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-muted via-transparent to-transparent"></div>
          </div>
          <div class="absolute -bottom-6 -right-6 md:-right-12 bg-primary rounded-2xl p-6 md:p-8 shadow-[0_20px_60px_hsl(var(--primary)/0.4)] max-w-[240px]">
            <p class="text-primary-foreground font-display font-bold text-2xl md:text-3xl">VIP</p>
            <p class="text-primary-foreground/70 font-light text-sm mt-1">Consegna a yacht, hotel e ville private</p>
          </div>
        </div>

        <div class="order-1 lg:order-2" data-reveal data-reveal-delay="100">
          <span class="text-primary font-display text-xs font-bold uppercase tracking-[0.4em] mb-4 block">
            Il Nostro Core
          </span>
          <h2 class="font-display text-4xl md:text-6xl font-black text-foreground leading-[1.05] mb-8">
            Esplora la Sardegna <span class="italic font-light text-primary">con stile</span>
          </h2>
          <div class="space-y-6 text-muted-foreground text-lg font-light leading-relaxed">
            <p>
              <a href="/flotta/fiat-panda" class="text-blue-600 font-medium hover:underline hover:text-blue-700 transition-all">City Car</a>,{" "}
              <a href="/flotta/honda-sh" class="text-blue-600 font-medium hover:underline hover:text-blue-700 transition-all">Scooter</a> e{" "}
              <a href="/flotta/yamaha-raptor" class="text-blue-600 font-medium hover:underline hover:text-blue-700 transition-all">Quad</a> di
              ultima generazione per vivere ogni angolo della Costa Smeralda in totale libertà. Prenoti online in 2 minuti,
              firmi digitalmente e ritiri — oppure te lo portiamo noi.
            </p>
            <p>
              Il nostro <strong class="text-foreground font-medium">Servizio Consegna VIP</strong> è ciò che ci rende unici:
              il veicolo arriva direttamente al tuo yacht a Palau, alla tua villa a{" "}
              <a href="/noleggio-auto-a-porto-cervo" class="text-blue-600 font-medium hover:underline hover:text-blue-700 transition-all">Porto Cervo</a> o
              al tuo hotel a{" "}
              <a href="/noleggio-auto-a-san-teodoro" class="text-blue-600 font-medium hover:underline hover:text-blue-700 transition-all">San Teodoro</a>.{" "}
              <strong class="text-foreground font-medium">Zero stress. Zero code. Solo il mare.</strong>
            </p>
          </div>

          <div class="mt-10 pt-8 border-t border-border">
            <h3 class="font-display text-xl font-bold text-foreground mb-3">🏎️ Auto di Lusso & Supercar</h3>
            <p class="text-muted-foreground font-light mb-6">
              Disponibili <strong class="text-foreground font-medium">esclusivamente su richiesta</strong>.
              Contattaci per configurare la tua esperienza VIP su misura.
            </p>
            <a
              href="https://wa.me/393520459150?text=Ciao%2C%20vorrei%20info%20su%20noleggio%20VIP%20Car"
              target="_blank"
              rel="noopener noreferrer"
              data-wa-track="chisiamo_vip_car"
              class="inline-flex items-center justify-center gap-2 h-12 px-8 text-base font-semibold rounded-full bg-[#25D366] text-white hover:bg-[#20BD5A] shadow-lg transition-all"
            >
              <svg viewBox="0 0 32 32" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.907 15.907 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004 32 7.176 24.826 0 16.004 0zm9.302 22.602c-.388 1.092-1.938 1.998-3.146 2.264-.826.178-1.904.32-5.534-1.19-4.646-1.932-7.634-6.634-7.866-6.942-.222-.308-1.87-2.494-1.87-4.756 0-2.264 1.184-3.378 1.604-3.838.388-.424.916-.616 1.222-.616.152 0 .286.008.41.014.42.018.63.042.906.7.346.824 1.19 2.908 1.296 3.12.106.214.214.504.066.796-.138.3-.258.486-.472.744-.214.258-.44.458-.654.74-.196.244-.416.504-.178.924.238.42 1.058 1.746 2.272 2.83 1.562 1.394 2.876 1.826 3.286 2.03.308.152.674.128.922-.132.31-.336.694-.892 1.084-1.442.278-.392.628-.44.966-.306.342.128 2.164 1.02 2.534 1.208.37.186.616.278.708.434.09.156.09.892-.298 1.984z"/>
              </svg>
              Richiedi VIP Car su WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Trust marquee divider */}
  <section class="relative w-full flex items-center justify-center -my-8 z-20 pointer-events-none overflow-hidden">
    <div class="absolute w-[200%] left-1/2 -translate-x-1/2 bg-primary -rotate-2 py-4 shadow-[0_10px_40px_hsl(var(--primary)/0.3)] border-y border-primary/30 overflow-hidden">
      <div class="flex w-max">
        <div class="flex items-center flex-shrink-0 animate-marquee">
          {repeatedMarquee.map((item) => (
            <div class="flex items-center px-6 md:px-10 flex-shrink-0">
              <span class="text-primary-foreground font-display font-black text-sm md:text-xl uppercase tracking-[0.2em] whitespace-nowrap">
                {item}
              </span>
              <img src={gdisLogo} alt="GDIS" loading="lazy" class="h-6 md:h-8 w-auto opacity-90 drop-shadow-md ml-6 md:ml-10 flex-shrink-0" />
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="invisible py-4">
      <span class="font-display font-black text-xl uppercase tracking-[0.2em]">S</span>
    </div>
  </section>

  {/* Heavy transport */}
  <section class="relative py-24 md:py-32 bg-muted overflow-hidden">
    <div class="container px-4 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center max-w-6xl mx-auto">
        <div data-reveal>
          <span class="text-primary font-display text-xs font-bold uppercase tracking-[0.4em] mb-4 block">
            Servizi B2B
          </span>
          <h2 class="font-display text-3xl md:text-5xl font-black text-foreground leading-[1.05] mb-6">
            Trasporti Speciali <span class="italic font-light text-primary">& Merci</span>
          </h2>
          <p class="text-muted-foreground text-lg font-light leading-relaxed mb-8">
            Oltre alla mobilità turistica, GDIS opera nel settore dei trasporti pesanti. Effettuiamo{" "}
            <strong class="text-foreground font-medium">trasporto merci, trasporti eccezionali e trasporto di imbarcazioni</strong>.
            Operiamo esclusivamente con nostro personale qualificato (servizi con conducente), utilizzando la nostra flotta
            di TIR, Camion, Furgoni, Rimorchi e Semi-rimorchi.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="mailto:info@gdisservice.it"
              class="inline-flex items-center justify-center gap-2 h-12 px-8 text-base font-bold rounded-full bg-primary text-primary-foreground hover:bg-primary/90 transition-all"
            >
              Richiedi Preventivo Trasporti
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="https://wa.me/393520459150?text=Ciao%2C%20vorrei%20un%20preventivo%20per%20trasporto%20merci"
              target="_blank"
              rel="noopener noreferrer"
              data-wa-track="chisiamo_trasporto_merci"
              class="inline-flex items-center justify-center gap-2 h-12 px-8 text-base font-semibold rounded-full bg-[#25D366] text-white hover:bg-[#20BD5A] shadow-lg transition-all"
            >
              <svg viewBox="0 0 32 32" width="16" height="16" fill="currentColor" aria-hidden="true">
                <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.907 15.907 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004 32 7.176 24.826 0 16.004 0z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
        <div data-reveal data-reveal-delay="200">
          <div class="relative rounded-3xl overflow-hidden aspect-[4/3] shadow-2xl">
            <img src={transportUrl} alt="Trasporti pesanti GDIS" loading="lazy" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-muted via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-24 md:py-32 bg-background relative overflow-hidden">
    <div class="container px-4 relative z-10">
      <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
        <div class="w-full lg:w-1/3">
          <div class="sticky top-32" data-reveal>
            <span class="text-primary font-display text-sm font-bold uppercase tracking-[0.3em] mb-4 block">
              Supporto
            </span>
            <h2 class="font-display text-4xl md:text-5xl font-bold text-foreground mb-6 leading-tight">
              Domande <br />
              <span class="italic font-light text-muted-foreground">Frequenti.</span>
            </h2>
            <p class="text-muted-foreground text-lg font-light mb-10 leading-relaxed">
              Tutto quello che devi sapere prima di metterti alla guida. Trasparenza totale, zero sorprese.
            </p>
            <div class="bg-primary/5 p-8 rounded-3xl border border-primary/10">
              <h4 class="font-display font-semibold text-foreground mb-2">Hai altre domande?</h4>
              <p class="text-sm text-muted-foreground mb-6 font-light">
                Il nostro team è a tua disposizione su WhatsApp per chiarire ogni dubbio.
              </p>
              <a
                href="https://wa.me/393520459150"
                target="_blank"
                rel="noopener noreferrer"
                data-wa-track="faq_chisiamo"
                class="inline-flex items-center justify-center gap-2 w-full h-12 px-6 text-base font-semibold rounded-full bg-[#25D366] hover:bg-[#1EBE5D] text-white shadow-md hover:shadow-lg transition-all"
              >
                <svg viewBox="0 0 32 32" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.907 15.907 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004 32 7.176 24.826 0 16.004 0z"/>
                </svg>
                Chatta con noi
              </a>
            </div>
          </div>
        </div>
        <div class="w-full lg:w-2/3">
          <FaqList items={faqs} />
        </div>
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden bg-[hsl(var(--brand-dark))]">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_50%,hsl(var(--primary)/0.15),transparent)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_80%,hsl(var(--primary)/0.25),transparent_50%)]"></div>
    <div class="container px-4 relative z-10 text-center">
      <div data-reveal>
        <h2 class="font-display text-4xl md:text-6xl lg:text-7xl font-black text-primary-foreground leading-[1.05] mb-6">
          Pronto a <span class="italic font-light text-primary">esplorare</span><br />
          la Sardegna?
        </h2>
        <p class="text-primary-foreground/50 text-lg md:text-xl max-w-2xl mx-auto font-light mb-12">
          Scegli il tuo veicolo, prenota in 2 minuti e parti. Nessuna burocrazia.
        </p>
        <a
          href="/prenotaora"
          class="inline-flex items-center justify-center gap-2 h-16 px-14 text-lg font-black rounded-full bg-primary-foreground text-primary hover:bg-primary-foreground/90 shadow-[0_0_50px_hsl(var(--primary)/0.4),0_20px_60px_rgba(0,0,0,0.3)] hover:shadow-[0_0_70px_hsl(var(--primary)/0.6)] transition-all duration-500"
        >
          Prenota Ora
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <div class="mt-8">
          <a
            href="https://wa.me/393520459150"
            target="_blank"
            rel="noopener noreferrer"
            data-wa-track="chisiamo_footer_cta"
            class="inline-flex items-center justify-center gap-2 h-12 px-8 text-base font-medium rounded-full text-primary-foreground/50 hover:text-primary-foreground hover:bg-primary-foreground/5 transition-all"
          >
            <svg viewBox="0 0 32 32" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.907 15.907 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004 32 7.176 24.826 0 16.004 0z"/>
            </svg>
            Oppure contattaci su WhatsApp
          </a>
        </div>
      </div>
