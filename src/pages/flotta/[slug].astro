---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { buildFaqSchema, SITE_URL } from "@/lib/siteSchema";

export async function getStaticPaths() {
  const fleet = await getCollection("fleet");
  return fleet.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

/**
 * Astro 5 content layer infers nested array-element fields as optional even when
 * the Zod schema requires them. Cast to DeepRequired — runtime is Zod-validated.
 */
type DeepRequired<T> = T extends Array<infer U>
  ? Array<DeepRequired<U>>
  : T extends object
    ? { [K in keyof T]-?: DeepRequired<T[K]> }
    : T;

const { entry } = Astro.props;
const v = entry.data as DeepRequired<typeof entry.data>;

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Flotta", url: "/" },
  { name: v.name, url: v.canonical },
];

const productSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": v.jsonLdType,
  name: `${v.name} — Noleggio Olbia e Costa Smeralda`,
  description: v.description,
  brand: { "@type": "Brand", name: v.jsonLdBrand },
  manufacturer: { "@type": "Organization", name: v.jsonLdManufacturer },
  model: v.jsonLdModel,
  image: v.heroImage,
  ...v.jsonLdExtras,
  offers: {
    "@type": "Offer",
    priceCurrency: "EUR",
    price: String(v.pricePerDay),
    availability: "https://schema.org/InStock",
    priceValidUntil: v.priceValidUntil,
    url: `${SITE_URL}${v.canonical}`,
    seller: { "@id": `${SITE_URL}/#organization` },
  },
};

const faqSchema = buildFaqSchema(v.faq);
---

<BaseLayout
  title={v.title}
  description={v.description}
  canonical={v.canonical}
  jsonLd={[productSchema, faqSchema]}
  breadcrumbs={breadcrumbs}
  ogType="product"
  lcpImage={{ href: v.heroImage, type: "image/webp" }}
>
  {/* HERO */}
  <section class="relative min-h-[85vh] flex items-center overflow-hidden bg-[radial-gradient(ellipse_at_center,hsl(var(--primary)/0.15),hsl(var(--brand-dark))_70%)]">
    <div class="absolute inset-0">
      <img src={v.heroImage} alt={v.name} class="w-full h-full object-cover opacity-20" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--brand-dark))] via-transparent to-[hsl(var(--brand-dark)/0.6)]"></div>
    </div>
    <div class="container relative z-10 py-32">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div data-reveal>
          <p class="text-sm font-semibold tracking-[0.3em] uppercase text-primary mb-4">{v.heroLabel}</p>
          <h1 class="text-4xl md:text-5xl lg:text-7xl font-display font-bold text-primary-foreground leading-[1.1] mb-6">
            {v.heroH1Top}<span class="block text-primary">{v.heroH1Bottom}</span>
          </h1>
          <p class="text-primary-foreground/60 text-lg max-w-lg mb-8">{v.heroSubtitle}</p>
          <div class="flex flex-wrap gap-3 mb-10">
            {v.heroBadges.map((badge) => (
              <span class="px-4 py-2 rounded-full bg-primary/15 text-primary border border-primary/30 text-sm font-medium backdrop-blur-sm">
                {badge}
              </span>
            ))}
          </div>
          <a
            href="/prenotaora"
            class="inline-flex items-center justify-center gap-2 h-14 px-10 text-lg font-semibold rounded-full bg-primary text-primary-foreground hover:bg-brand-blue-deep shadow-lg shadow-primary/30 transition-all"
          >
            Prenota Ora
          </a>
        </div>
        <div class="hidden md:block" data-reveal data-reveal-delay="200">
          <img
            src={v.heroImage}
            alt={v.name}
            class="w-full max-w-lg mx-auto drop-shadow-[0_20px_60px_hsl(var(--primary)/0.3)] rounded-2xl"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="container pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  {/* FEATURE SECTIONS */}
  {v.featureSections.map((section, i) => (
    <section class:list={["py-24", i % 2 === 0 ? "bg-background" : "bg-muted/30"]}>
      <div class="container">
        <div class="grid md:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">
          <div
            class:list={["border-l-4 border-primary pl-8", section.reverse ? "order-1 md:order-2" : ""]}
            data-reveal
          >
            <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-3">{section.label}</p>
            <h2 class="text-3xl md:text-4xl font-display font-bold text-foreground mb-6">{section.title}</h2>
            {section.body.map((p) => (
              <p class="text-muted-foreground leading-relaxed mb-4 last:mb-0" set:html={p} />
            ))}
          </div>
          <div class:list={[section.reverse ? "order-2 md:order-1" : ""]} data-reveal data-reveal-delay="100">
            <img src={section.image} alt={section.imageAlt} loading="lazy" decoding="async" class="rounded-2xl shadow-2xl w-full" />
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* COCKPIT SPECS */}
  <section class="py-24 bg-[hsl(var(--brand-dark))] text-primary-foreground relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,hsl(var(--primary)/0.08),transparent_60%)]"></div>
    <div class="container relative z-10">
      <div class="text-center mb-16" data-reveal>
        <p class="text-sm font-semibold tracking-[0.3em] uppercase text-primary mb-3">Specifiche</p>
        <h2 class="text-3xl md:text-5xl font-display font-bold">Scheda Tecnica</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {v.specs.map((spec, i) => (
          <div
            class="group rounded-xl p-6 text-center bg-primary-foreground/5 border border-primary-foreground/10 backdrop-blur-md hover:border-primary/50 hover:shadow-[0_0_30px_hsl(var(--primary)/0.15)] transition-all duration-300"
            data-reveal
            data-reveal-delay={String((i % 3) * 100)}
          >
            {spec.icon === "gauge" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>}
            {spec.icon === "fuel" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><line x1="3" x2="15" y1="22" y2="22"/><line x1="4" x2="14" y1="9" y2="9"/><path d="M14 22V4a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v18"/><path d="M14 13h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2a2 2 0 0 0 2-2V9.83a2 2 0 0 0-.59-1.42L18 5"/></svg>}
            {spec.icon === "users" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
            {spec.icon === "settings" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>}
            {spec.icon === "wind" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>}
            {spec.icon === "luggage" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="M6 20a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2"/><path d="M8 18V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v14"/><path d="M10 20h4"/><circle cx="16" cy="20" r="2"/><circle cx="8" cy="20" r="2"/></svg>}
            {spec.icon === "shield" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>}
            {spec.icon === "mountain" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>}
            {spec.icon === "wrench" && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 mx-auto mb-3 text-primary"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>}
            <p class="text-xs uppercase tracking-wider text-primary-foreground/50 mb-1">{spec.label}</p>
            <p class="font-display font-semibold text-lg text-primary-foreground">{spec.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* SCENARIO CARDS */}
  <section class="py-24 bg-background">
    <div class="container max-w-5xl">
      <div class="text-center mb-16" data-reveal>
        <p class="text-sm font-semibold tracking-[0.3em] uppercase text-primary mb-3">Dove ti porta</p>
        <h2 class="text-3xl md:text-5xl font-display font-bold text-foreground">Perfetto per...</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {v.scenarios.map((s, i) => (
          <div
            class:list={[
              "rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2",
              s.highlight
                ? "bg-primary text-primary-foreground shadow-[0_10px_40px_hsl(var(--primary)/0.4)]"
                : "bg-muted/50 border border-border/50 text-foreground",
            ]}
            data-reveal
            data-reveal-delay={String(i * 120)}
          >
            <div class:list={["mb-4", s.highlight ? "text-primary-foreground" : "text-primary"]}>
              {s.icon === "map-pin" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>}
              {s.icon === "shopping-bag" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>}
              {s.icon === "users" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
              {s.icon === "parking" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>}
              {s.icon === "bike" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>}
              {s.icon === "zap" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
              {s.icon === "mountain" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>}
              {s.icon === "flame" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>}
              {s.icon === "camera" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>}
              {s.icon === "star" && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>}
            </div>
            <h3 class="font-display font-bold text-xl mb-3">{s.title}</h3>
            <p class:list={["leading-relaxed", s.highlight ? "text-primary-foreground/80" : "text-muted-foreground"]}>
              {s.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* WHY SECTION */}
  <section class="py-20 md:py-24 bg-muted/30">
    <div class="container max-w-3xl">
      <div data-reveal>
        <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-3">{v.whySection.label}</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-foreground mb-6 leading-tight">{v.whySection.title}</h2>
        {v.whySection.paragraphs.map((p) => (
          <p class="text-base md:text-lg text-muted-foreground leading-relaxed mb-4 last:mb-0" set:html={p} />
        ))}
      </div>
    </div>
  </section>

  {/* LOCALITA SECTION */}
  <section class="py-20 md:py-24 bg-background">
    <div class="container max-w-3xl">
      <div data-reveal>
        <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-3">{v.localitaSection.label}</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-foreground mb-6 leading-tight">{v.localitaSection.title}</h2>
        <p class="text-base md:text-lg text-muted-foreground leading-relaxed mb-4">{v.localitaSection.intro}</p>
        <ul class="space-y-3 text-base md:text-lg text-foreground/85">
          {v.localitaSection.items.map((item) => (
            <li set:html={item} />
          ))}
        </ul>
        <p class="text-sm text-muted-foreground mt-6" set:html={v.localitaSection.outro} />
      </div>
    </div>
  </section>

  {/* FAQ on primary background */}
  <section class="py-24 bg-primary relative overflow-hidden">
    <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_20px,hsl(0_0%_100%/0.02)_20px,hsl(0_0%_100%/0.02)_40px)]"></div>
    <div class="container max-w-3xl relative z-10">
      <div class="text-center mb-12" data-reveal>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-primary-foreground">Domande Frequenti</h2>
      </div>
      <div class="space-y-4">
        {v.faq.map((faq) => (
          <details class="faq-item rounded-2xl bg-primary-foreground/10 backdrop-blur-md border border-primary-foreground/20 px-6 hover:bg-primary-foreground/15 transition-all duration-300">
            <summary class="py-5 flex items-center justify-between gap-4 text-left font-semibold text-primary-foreground">
              <span>{faq.q}</span>
              <svg class="faq-chevron h-5 w-5 flex-shrink-0 text-primary-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="text-primary-foreground/70 font-light leading-relaxed pb-5">
              <p set:html={faq.a} />
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* GRAND CTA */}
  <section class="py-32 relative overflow-hidden bg-primary">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_20px,hsl(0_0%_100%/0.03)_20px,hsl(0_0%_100%/0.03)_40px)]"></div>
    </div>
    <div class="container relative z-10 text-center">
      <div data-reveal>
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-primary-foreground mb-6">{v.ctaTitle}</h2>
        <p class="text-primary-foreground/80 text-lg md:text-xl max-w-2xl mx-auto mb-12">{v.ctaSubtitle}</p>
        <a
          href="/prenotaora"
          class="inline-flex items-center justify-center gap-2 h-16 px-12 text-lg font-bold rounded-full bg-primary-foreground text-primary hover:bg-primary-foreground/90 shadow-[0_10px_40px_hsl(0_0%_0%/0.3)] hover:shadow-[0_15px_50px_hsl(0_0%_0%/0.4)] hover:scale-[1.03] active:scale-[0.97] transition-all duration-300"
        >
          {v.ctaButtonLabel}
        </a>
        <p class="mt-6 text-primary-foreground/70 text-sm">
          Domande?{" "}
          <a href="/contatti" class="text-primary-foreground font-semibold underline-offset-4 hover:underline">Contattaci</a>{" "}
          ·{" "}
          <a href="/" class="text-primary-foreground font-semibold underline-offset-4 hover:underline">Torna alla home</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
